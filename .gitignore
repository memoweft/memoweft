# ── Secrets — NEVER commit ──
.env
.env.local
.env.*.local
*.pem
*.key

# ── Local user data (evidence / profiles / conversations) ──
*.db
*.db-journal
*.sqlite
dla.db
# 例外：冻结的迁移测试 fixture（真 0.1.0 schema，供"无损升级"测试，别忽略）
!tests/fixtures/*.db
testbench/*.db
testbench/seed-*.ps1
apps/*/data/
logs/
*.db-shm
*.db-wal

# ── Build output ──
dist/
coverage/
*.tsbuildinfo

# ── Dependencies ──
node_modules/

# ── OS / editor cruft ──
.DS_Store
Thumbs.db
*.log
.idea/
.vscode/

# ── Local tooling / scratch (never commit) ──
mcp-publisher*
dogfood*.mjs
tmp/
temp/
scratch/
.doc-snippets-tmp/
.cache/
task-logs/
worklogs/
debug-output/

# ── AI/tool operation history ──
.agent_logs/
.agents/logs/
.agents/history/
.claude/logs/
.claude/history/
.claude/transcripts/
.claude/sessions/
.cursor/logs/

# ── Unrelated local artifacts / generated output (never commit) ──
artifacts/
site/
*.mp4

# ── bench 部分跑产物（PARTIAL RUN，不入库；全量基线 consolidation-baseline.* 仍提交） ──
# 只忽略 <date>-<sha>-consolidation-<...>.{md,json}；既有 bench/runs/2026-07-10-retrieval-ablation.md 不受影响。
bench/runs/*-consolidation-*.json
bench/runs/*-consolidation-*.md

# ── test:live 产物（Phase 2 §15.4：nightly 编排 test:live 时落 bench/runs/*-live.*，可查但不入库） ──
# 覆盖 <date>-<sha>-consolidation-live.* 与 <date>-<sha>-retrieval-live.*；既有 *-retrieval-ablation.md 不受影响。
bench/runs/*-live.md
bench/runs/*-live.json
