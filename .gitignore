# ── Secrets — NEVER commit ──
.env
.env.local
.env.*.local
*.pem
*.key

# ── Local user data (evidence / profiles / conversations) ──
*.db
*.db-journal
*.sqlite
dla.db
# 例外：冻结的迁移测试 fixture（真 0.1.0 schema，供"无损升级"测试，别忽略）
!tests/fixtures/*.db
testbench/*.db
testbench/seed-*.ps1
apps/*/data/
logs/
*.db-shm
*.db-wal

# ── Build output ──
dist/
coverage/
*.tsbuildinfo

# ── Dependencies ──
node_modules/

# ── OS / editor cruft ──
.DS_Store
Thumbs.db
*.log
.idea/
.vscode/

# ── Local tooling / scratch (never commit) ──
mcp-publisher*
dogfood*.mjs
tmp/
temp/
scratch/
.cache/
task-logs/
worklogs/
debug-output/

# ── AI/tool operation history ──
.agent_logs/
.agents/logs/
.agents/history/
.claude/logs/
.claude/history/
.claude/transcripts/
.claude/sessions/
.cursor/logs/

# ── Unrelated local artifacts / generated output (never commit) ──
artifacts/
site/
*.mp4
