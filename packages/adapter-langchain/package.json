{
  "name": "@memoweft/adapter-langchain",
  "version": "0.1.0",
  "description": "LangChain adapter for MemoWeft — inject long-term memory via a BaseRetriever (recall) and persist tool results via a BaseCallbackHandler + the user's turn via a host closure (write).",
  "keywords": [
    "langchain",
    "langchain-core",
    "retriever",
    "callback-handler",
    "memoweft",
    "memory",
    "llm"
  ],
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "examples/**/*.ts",
    "README.md",
    "README.zh-CN.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/memoweft/memoweft.git",
    "directory": "packages/adapter-langchain"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json",
    "test": "node --test \"tests/**/*.test.ts\"",
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "peerDependencies": {
    "@langchain/core": "^1",
    "langchain": "^1",
    "memoweft": "^0.6.0"
  },
  "peerDependenciesMeta": {
    "langchain": {
      "optional": true
    }
  },
  "devDependencies": {
    "@langchain/core": "^1.2.2",
    "langchain": "^1.5.3",
    "memoweft": "*"
  }
}
