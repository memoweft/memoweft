{
  "name": "@memoweft/adapter-claude-agent-sdk",
  "version": "0.1.0",
  "description": "Claude Agent SDK adapter for MemoWeft — inject long-term memory via a UserPromptSubmit hook (recall + write the user's turn) and persist tool results via a PostToolUse hook (write).",
  "keywords": [
    "claude-agent-sdk",
    "claude",
    "anthropic",
    "memoweft",
    "memory",
    "llm",
    "hooks"
  ],
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.map",
    "examples/**/*.ts",
    "README.md",
    "README.zh-CN.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/memoweft/memoweft.git",
    "directory": "packages/adapter-claude-agent-sdk"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json",
    "test": "node --test \"tests/**/*.test.ts\"",
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "peerDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.207",
    "memoweft": "^0.5.1 || ^0.6.0"
  },
  "devDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.207",
    "memoweft": "*"
  }
}
