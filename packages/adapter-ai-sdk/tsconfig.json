{
  // Vercel AI SDK 适配器类型检查档：extends 根 base（NodeNext / strict / 带 .ts 后缀相对 import 等），
  // include 本包 src/tests。ai / memoweft 类型解析靠 workspace 软链（devDependencies）——先 npm run build 出根 dist。
  // rootDir 指向仓库根：本包 tests 复用共享契约套件 tests/adapter-kit/（仓库根下），noEmit 档下 rootDir 仅
  //   用于「所有源文件须在 rootDir 下」这一校验，指到根才容得下跨包共享的 kit（不影响输出，build 走另档）。
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "rootDir": "../..",
    "noEmit": true
  },
  "include": ["src", "tests"]
}
