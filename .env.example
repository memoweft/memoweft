# ── MemoWeft 环境变量模板 ────────────────────────────────────────
# 用法：把本文件复制成 .env（同目录），再把下面占位符换成你自己的真实值。
#   Windows(PowerShell): Copy-Item .env.example .env
#   macOS/Linux:         cp .env.example .env
# ⚠️ .env 含密钥，已被 .gitignore 忽略、绝不提交；本模板（.env.example）不含真实 key，可提交。
#
# 命名说明：代码先读 MEMOWEFT_* 主名、读不到再回退旧名 DLA_*（老 .env 零改动继续可用）。
# 新装的人一律用下面的 MEMOWEFT_* 主名即可。

# ── 1. 对话大模型（chat）· 必填 ─────────────────────────────────
# 必填：这三项不填，一聊天就报错（对话模型是唯一硬依赖）。
# 端点须是 OpenAI 兼容的 /chat/completions（云端如小米 MiMo，或本地 Ollama / LM Studio 均可）。
MEMOWEFT_LLM_BASE_URL=https://your-endpoint/v1
MEMOWEFT_LLM_API_KEY=sk-your-key-here
MEMOWEFT_LLM_MODEL=your-chat-model

# ── 2. 写路径小快模型（write）· 可选 ────────────────────────────
# 可选：不填自动回退上面的对话大模型、不报错。
# 填了后台写路径（整理事件 / 生成画像 / 归因）改用小快模型，提速、不拖慢“更新画像”。
MEMOWEFT_WRITE_LLM_BASE_URL=https://your-endpoint/v1
MEMOWEFT_WRITE_LLM_API_KEY=sk-your-key-here
MEMOWEFT_WRITE_LLM_MODEL=your-small-fast-model
# 部署位置（档2·可选）：cloud（默认）/ local。填 local = 本地写模型，能私密消化“行为观察”
#   （observed 默认不上云的证据）；填 cloud（或不填）则这些观察不会被消化，除非在记忆管理里单独授权上云。
#   ⚠ 这只是【声明】：填 local 却把上面的 BASE_URL 指向云端端点，敏感证据照样会上云——部署方自负。
MEMOWEFT_WRITE_LLM_TIER=cloud

# ── 3. 嵌入 / 向量模型（embed）· 可选 ───────────────────────────
# 可选：不填召回降级为空——画像照写，只是回话不注入历史（不报错）。
# 填了用于语义召回。作者用本地 Ollama bge-m3（多语言 / 中文好，1024 维）。
MEMOWEFT_EMBED_BASE_URL=http://localhost:11435/v1
MEMOWEFT_EMBED_API_KEY=ollama
MEMOWEFT_EMBED_MODEL=bge-m3

# ── 4. 体验界面开关（部署选项）─────────────────────────────────
# on  = 起体验界面网页（npm run experience，等同 npm run testbench，同一端口 7888）。
# off = 只把 MemoWeft 当库 import、不起网页（node testbench/server.mjs 会打印提示并直接退出）。
# 缺省 / 其它值 = 照常起网页。
MEMOWEFT_EXPERIENCE_UI=on
