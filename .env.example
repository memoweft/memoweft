# MemoWeft model configuration
#
# Copy this file to .env and replace the placeholders:
#   PowerShell: Copy-Item .env.example .env
#   macOS/Linux: cp .env.example .env
#
# Never commit the resulting .env file. New deployments should use the
# MEMOWEFT_* names below; legacy DLA_* aliases remain supported.

# Chat model (OpenAI-compatible /chat/completions endpoint)
# Required by model-backed conversation and profile-update flows. Evidence
# storage and the no-key demo do not require it.
MEMOWEFT_LLM_BASE_URL=https://your-endpoint/v1
MEMOWEFT_LLM_API_KEY=sk-your-key-here
MEMOWEFT_LLM_MODEL=your-chat-model

# Optional write-path model. When omitted, MemoWeft uses the chat model.
MEMOWEFT_WRITE_LLM_BASE_URL=https://your-endpoint/v1
MEMOWEFT_WRITE_LLM_API_KEY=sk-your-key-here
MEMOWEFT_WRITE_LLM_MODEL=your-small-fast-model
# Declares which built-in evidence-read flags apply to this endpoint.
# This is a routing declaration, not endpoint verification or access control.
MEMOWEFT_WRITE_LLM_TIER=cloud

# Optional embedding model. Core falls back to local FTS5 keyword recall when
# no embedder is configured; semantic/vector recall requires this endpoint.
MEMOWEFT_EMBED_BASE_URL=https://your-embedding-endpoint/v1
MEMOWEFT_EMBED_API_KEY=your-embedding-key
MEMOWEFT_EMBED_MODEL=your-embedding-model

# Optional diagnostic-host UI switch. Library consumers do not need this variable.
MEMOWEFT_EXPERIENCE_UI=on
