{
  "name": "memoweft",
  "version": "0.6.0",
  "description": "Portable, traceable long-term memory for AI applications that keeps evidence, inference, and conflicts distinct.",
  "keywords": [
    "llm",
    "agent",
    "memory",
    "cognition",
    "user-profile",
    "ai-memory",
    "long-term-memory",
    "memory-layer",
    "mcp",
    "user-memory",
    "local-first"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/memoweft/memoweft.git"
  },
  "bugs": {
    "url": "https://github.com/memoweft/memoweft/issues"
  },
  "homepage": "https://github.com/memoweft/memoweft#readme",
  "type": "module",
  "packageManager": "npm@11.12.1",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "README.md",
    "README.zh-CN.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "workspaces": [
    ".",
    "apps/*",
    "plugins/*",
    "packages/*"
  ],
  "scripts": {
    "typecheck": "tsc -p tsconfig.json",
    "test": "node --test \"tests/**/*.test.ts\" \"testbench/*.test.mjs\"",
    "test:coverage": "node --test --experimental-test-coverage \"tests/**/*.test.ts\" \"testbench/*.test.mjs\"",
    "test:e2e": "node --test \"tests/**/*.e2e.ts\"",
    "test:live": "node scripts/test-live.mjs",
    "lint": "eslint .",
    "format": "prettier --check .",
    "testbench": "node testbench/server.mjs",
    "collector": "node plugins/collector-active-window/run.mjs",
    "experience": "node testbench/server.mjs",
    "build": "tsc -p tsconfig.build.json",
    "demo": "npm run build && node examples/demo.ts",
    "api:update": "node scripts/api-snapshot.mjs",
    "api:check": "node scripts/api-snapshot.mjs --check",
    "prompts:update": "node scripts/prompt-hashes.mjs",
    "shared:update": "node scripts/gen-shared-assets.mjs",
    "shared:check": "node scripts/gen-shared-assets.mjs --check",
    "bench": "node bench/bulk-updateProfile.mjs",
    "bench:retrieval": "node bench/eval-retrieval.mjs",
    "bench:consolidation": "node bench/eval-consolidation.mjs",
    "smoke:dist": "node tests/smoke/dist-smoke.mjs",
    "docs:links": "node scripts/doc-links.mjs",
    "docs:snippets": "node scripts/doc-snippets.mjs",
    "dev:core": "tsc -p tsconfig.build.json --watch",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "peerDependencies": {
    "better-sqlite3": ">=9"
  },
  "peerDependenciesMeta": {
    "better-sqlite3": {
      "optional": true
    }
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/node": "^24.0.0",
    "better-sqlite3": ">=9",
    "eslint": "^9.0.0",
    "@eslint/js": "^9.0.0",
    "typescript-eslint": "^8.0.0",
    "prettier": "^3.0.0"
  },
  "directories": {
    "doc": "docs",
    "example": "examples",
    "test": "tests"
  }
}
